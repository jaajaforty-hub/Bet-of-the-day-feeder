
<%- include("partials/header.ejs") %>
    
<main class="day-form" style="display: block;">
  <h1 class="day">FRIDAY</h1>

    <form action="friday" method="POST" class="form" id="form">

      <label class="team-name">TEAM---1</label>
      <input type="text" name="name_team_one" class="t-name">
      <label class="team-name">CONTRY</label>
      <input type="text" name="country_team_one" class="t-name">
      <label class="team-name">ODD</label>
      <input type="text" name="odd_team_one" class="t-name">
      <label class="team-name">TIME</label>
      <input type="text" name="time_team_one" class="t-name">
      <label class="team-name">PROBABILITY</label>
      <input type="text" name="prob_team_one" class="t-name">

      <label class="team-name">TEAM---2</label>
      <input type="text" name="name_team_two" class="t-name">
      <label class="team-name">CONTRY</label>
      <input type="text" name="country_team_two" class="t-name">
      <label class="team-name">ODD</label>
      <input type="text" name="odd_team_two" class="t-name">
      <label class="team-name">TIME</label>
      <input type="text" name="time_team_two" class="t-name">
      <label class="team-name">PROBABILITY</label>
      <input type="text" name="prob_team_two" class="t-name">
      

      <label class="team-name">TEAM---3</label>
      <input type="text" name="name_team_three" class="t-name">
      <label class="team-name">CONTRY</label>
      <input type="text" name="country_team_three" class="t-name">
      <label class="team-name">ODD</label>
      <input type="text" name="odd_team_three" class="t-name">
      <label class="team-name">TIME</label>
      <input type="text" name="time_team_three" class="t-name">
      <label class="team-name">PROBABILITY</label>
      <input type="text" name="prob_team_three" class="t-name">
      
  
      <label class="team-name">TEAM---4</label>
      <input type="text" name="name_team_four" class="t-name">
      <label class="team-name">CONTRY</label>
      <input type="text" name="country_team_four" class="t-name">
      <label class="team-name">ODD</label>
      <input type="text" name="odd_team_four" class="t-name">
      <label class="team-name">TIME</label>
      <input type="text" name="time_team_four" class="t-name">
      <label class="team-name">PROBABILITY</label>
      <input type="text" name="prob_team_four" class="t-name">

      <button type="submit" class="submit-button" >SUBMIT</button>
      <button type="button" class="clear-button" id="clear-button">CLEAR ALL</button>

    </form>

    <div class="message"><%= locals.message%></div>
    
</main>

<script>

  const fields = document.querySelectorAll("input");
  document.getElementById("clear-button").addEventListener("click", () => {
    fields.forEach(field => field.value = "");
  });

</script>

